@app.route('/login', methods=['GET', 'POST'])
def login():
    client_ip = request.remote_addr
    
    # Rate limiting
    if not rate_limit(f'login_{client_ip}', limit=5, window=60):
        return render_template('login.html', error="Too many login attempts. Try again later.")
    
    if request.method == 'POST':
        username = request.form['username']
        password = request.form['password']
        
        is_locked, lock_msg = check_account_lockout(username)
        if is_locked:
            return render_template('login.html', error=lock_msg)
        
        conn = get_db()
        user = conn.execute("SELECT * FROM users WHERE username = ?", (username,)).fetchone()
        conn.close()
        
        if user and verify_password(password, user['password']):
            reset_failed_attempts(username)
            log_activity(user['id'], 'LOGIN_SUCCESS', 'Successful login', client_ip)
            
            # Check 2FA
            conn = get_db()
            user_2fa = conn.execute("SELECT enabled FROM user_2fa WHERE user_id = ?", (user['id'],)).fetchone()
            conn.close()
            
            session['user_id'] = user['id']
            session['username'] = user['username']
            session['role'] = user['role']
            session['requires_2fa'] = user_2fa and user_2fa['enabled'] if user_2fa else False
            
            if session['requires_2fa']:
                return redirect(url_for('verify_2fa_page'))
            
            session.permanent = True
            return redirect(url_for('dashboard'))
        else:
            record_failed_attempt(username)
            log_activity(0, 'LOGIN_FAILED', f'Failed login for {username}', client_ip)
            return render_template('login.html', error='Invalid credentials')
    
    return render_template('login.html', csrf_token=generate_csrf_token())

@app.route('/verify-2fa', methods=['GET', 'POST'])
def verify_2fa_page():
    if 'user_id' not in session or not session.get('requires_2fa', False):
        return redirect(url_for('login'))
    
    if request.method == 'POST':
        code = request.form.get('code')
        if verify_2fa(session['user_id'], code):
            session['requires_2fa'] = False
            session.permanent = True
            log_activity(session['user_id'], '2FA_SUCCESS', '2FA verification successful', request.remote_addr)
            return redirect(url_for('dashboard'))
        else:
            log_activity(session['user_id'], '2FA_FAILED', 'Invalid 2FA code', request.remote_addr)
            return render_template('verify_2fa.html', error='Invalid verification code')
    
    return render_template('verify_2fa.html')

