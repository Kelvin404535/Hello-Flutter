# ========== 6. 2FA FUNCTIONS ==========
def init_2fa_table():
    conn = get_db()
    conn.execute('''
        CREATE TABLE IF NOT EXISTS user_2fa (
            user_id INTEGER PRIMARY KEY,
            secret TEXT,
            enabled BOOLEAN DEFAULT 0,
            backup_codes TEXT,
            FOREIGN KEY (user_id) REFERENCES users(id)
        )
    ''')
    conn.commit()
    conn.close()

init_2fa_table()

def setup_2fa(user_id):
    conn = get_db()
    existing = conn.execute("SELECT * FROM user_2fa WHERE user_id = ?", (user_id,)).fetchone()
    
    secret = pyotp.random_base32()
    
    if existing:
        conn.execute("UPDATE user_2fa SET secret = ?, enabled = 0 WHERE user_id = ?", (secret, user_id))
    else:
        conn.execute("INSERT INTO user_2fa (user_id, secret, enabled) VALUES (?, ?, 0)", (user_id, secret))
    
    user = conn.execute("SELECT username FROM users WHERE id = ?", (user_id,)).fetchone()
    conn.commit()
    conn.close()
    
    totp = pyotp.TOTP(secret)
    uri = totp.provisioning_uri(user['username'], issuer_name="SmartSiloSystem")
    
    qr = qrcode.make(uri)
    buffer = BytesIO()
    qr.save(buffer, format="PNG")
    qr_base64 = base64.b64encode(buffer.getvalue()).decode()
    
    backup_codes = [secrets.token_hex(4) for _ in range(5)]
    conn = get_db()
    conn.execute("UPDATE user_2fa SET backup_codes = ? WHERE user_id = ?", (','.join(backup_codes), user_id))
    conn.commit()
    conn.close()
    
    return {'secret': secret, 'qr_code': qr_base64, 'backup_codes': backup_codes}

def verify_2fa(user_id, code):
    conn = get_db()
    user_2fa = conn.execute("SELECT secret, enabled, backup_codes FROM user_2fa WHERE user_id = ?", (user_id,)).fetchone()
    conn.close()
    
    if not user_2fa or not user_2fa['enabled']:
        return False
    
    # Check backup codes
    if user_2fa['backup_codes']:
        backup_codes = user_2fa['backup_codes'].split(',')
        if code in backup_codes:
            backup_codes.remove(code)
            conn = get_db()
            conn.execute("UPDATE user_2fa SET backup_codes = ? WHERE user_id = ?", (','.join(backup_codes), user_id))
            conn.commit()
            conn.close()
            return True
    
    totp = pyotp.TOTP(user_2fa['secret'])
    return totp.verify(code)

def enable_2fa(user_id, code):
    conn = get_db()
    user_2fa = conn.execute("SELECT secret FROM user_2fa WHERE user_id = ?", (user_id,)).fetchone()
    if not user_2fa:
        conn.close()
        return False
    totp = pyotp.TOTP(user_2fa['secret'])
    if totp.verify(code):
        conn.execute("UPDATE user_2fa SET enabled = 1 WHERE user_id = ?", (user_id,))
        conn.commit()
        conn.close()
        return True
    conn.close()
    return False

def disable_2fa(user_id):
    conn = get_db()
    conn.execute("UPDATE user_2fa SET enabled = 0, secret = NULL, backup_codes = NULL WHERE user_id = ?", (user_id,))
    conn.commit()
    conn.close()

# ========== DECORATORS ==========
def login_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        if 'user_id' not in session:
            return redirect(url_for('login'))
        if session.get('requires_2fa', False):
            return redirect(url_for('verify_2fa_page'))
        return f(*args, **kwargs)
    return decorated

def admin_required(f):
    @wraps(f)
    def decorated(*args, **kwargs):
        if 'user_id' not in session:
            return redirect(url_for('login'))
        if session.get('role') != 'admin':
            abort(403)
        return f(*args, **kwargs)
    return decorated

# ========== RISK CALCULATION ==========
def calculate_risk(moisture, days_stored):
    if moisture is None or moisture == 0:
        return 'gray', 'No data entered'
    if moisture > 14 or days_stored > 90:
        return 'red', f'CRITICAL: {moisture}% moisture, {days_stored} days'
    elif moisture > 12.5 or days_stored > 60:
        return 'yellow', f'WARNING: {moisture}% moisture, {days_stored} days'
    else:
        return 'green', f'SAFE: {moisture}% moisture, {days_stored} days'

